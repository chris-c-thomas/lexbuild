{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "workspaces": {
    "packages/*": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.ts"]
    },
    "apps/astro": {
      "entry": ["src/pages/**/*.astro", "src/env.d.ts"],
      "project": ["src/**/*.{ts,astro}"]
    }
  },
  "ignoreDependencies": [
    // If needed for false positives like Prettier plugins
    "prettier-plugin-astro"
  ]
}