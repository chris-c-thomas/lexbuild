# Astro app environment variables
# Copy to .env.local for local development overrides.

# Content and navigation directories (relative to apps/astro/)
CONTENT_DIR=./content
NAV_DIR=./public/nav

# Search (set to false to disable search UI entirely)
ENABLE_SEARCH=true

# Meilisearch connection (standard port: 7700, Docker dev: 7711)
# Production uses /search (Caddy proxy mode, no key exposed client-side)
MEILI_URL=http://localhost:7700
MEILI_SEARCH_KEY=

# Base URL for sitemap and OpenGraph tags
SITE_URL=https://lexbuild.dev

# API base URL for Scalar spec (falls back to SITE_URL)
# Set to http://localhost:4322 for local API dev
# API_URL=http://localhost:4322
