---
import "@/styles/global.css";
import SEOHead from "@/components/seo/SEOHead.astro";
import ThemeToggle from "@/components/ui/ThemeToggle";
import { Sidebar } from "@/components/sidebar/Sidebar";
import { MobileNav } from "@/components/sidebar/MobileNav";
import { SearchDialog } from "@/components/search/SearchDialog";
import { SourcesDropdown } from "@/components/nav/SourcesDropdown";
import type { SourceId, PageSEO } from "@/lib/types";
import { SOURCES } from "@/lib/sources";

interface Props {
  seo: PageSEO;
  source?: SourceId;
}

const { seo, source } = Astro.props;
const currentPath = Astro.url.pathname;
const showSidebar = source ? SOURCES[source]?.hasSidebar !== false : false;
const enableSearch = (import.meta.env.ENABLE_SEARCH ?? "false") === "true";
const meiliUrl = import.meta.env.MEILI_URL ?? "http://127.0.0.1:7700";
const isProxyMode = meiliUrl.startsWith("/");
const meiliSearchKey = isProxyMode ? undefined : (import.meta.env.MEILI_SEARCH_KEY ?? "");
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <SEOHead seo={seo} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="theme-color" content="#ffffff" id="theme-color" />
    <!-- Prevent flash of wrong theme — default is light, dark only if explicitly stored -->
    <script is:inline>
      (function () {
        var d = document.documentElement;
        if (localStorage.getItem("theme") === "dark") {
          d.classList.add("dark");
          d.style.colorScheme = "dark";
          document.getElementById("theme-color").setAttribute("content", "#0e1821");
        } else {
          d.style.colorScheme = "light";
        }
      })();
    </script>
    <!-- Google tag (gtag.js) -->
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-2S71DGYMWR"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-2S71DGYMWR");
    </script>
    <!-- Microsoft Clarity -->
    <script is:inline>
      (function (c, l, a, r, i, t, y) {
        c[a] =
          c[a] ||
          function () {
            (c[a].q = c[a].q || []).push(arguments);
          };
        t = l.createElement(r);
        t.async = 1;
        t.src = "https://www.clarity.ms/tag/" + i;
        y = l.getElementsByTagName(r)[0];
        y.parentNode.insertBefore(t, y);
      })(window, document, "clarity", "script", "vyh6ex8n4s");
    </script>
  </head>
  <body class="bg-background text-foreground min-h-screen antialiased">
    <a
      href="#main-content"
      class="bg-background text-foreground ring-ring pointer-events-none fixed top-2 left-2 z-[100] rounded-md px-4 py-2 text-sm font-medium opacity-0 ring-2 transition-opacity focus:pointer-events-auto focus:opacity-100">
      Skip to content
    </a>
    <header
      class="border-border bg-background/95 supports-[backdrop-filter]:bg-background/60 sticky top-0 z-50 border-b backdrop-blur">
      <div class="mx-auto flex h-14 items-center justify-between px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-6">
          <MobileNav client:load source={source} currentPath={currentPath} />
          <a
            href="/"
            class="font-display text-slate-blue-900 dark:text-slate-blue-200 inline-flex items-center gap-2 text-2xl font-semibold">
            <svg
              class="h-6 w-6"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.75"
              stroke-linecap="round"
              stroke-linejoin="round">
              <path
                d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z">
              </path><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"></path><path
                d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65">
              </path>
            </svg>
            LexBuild
          </a>
          <nav class="text-md hidden items-center gap-5 pl-2 font-normal lg:flex">
            <SourcesDropdown client:load source={source} />
            <a
              href="/docs/cli/installation"
              class:list={[
                "nav-link inline-flex items-center gap-1.5 transition-colors",
                currentPath.startsWith("/docs/cli")
                  ? "text-foreground font-semibold"
                  : "text-muted-foreground hover:text-slate-blue-700 dark:hover:text-slate-blue-300",
              ]}>
              CLI
            </a>
            <a
              href="/docs/api"
              class:list={[
                "nav-link inline-flex items-center gap-1.5 transition-colors",
                currentPath === "/docs/api"
                  ? "text-foreground font-semibold"
                  : "text-muted-foreground hover:text-slate-blue-700 dark:hover:text-slate-blue-300",
              ]}>
              API
            </a>
            <span
              class="inline-flex items-start gap-0.5 text-muted-foreground/50 cursor-default select-none"
              aria-disabled="true">
              MCP
              <span class="relative -top-1 rounded bg-slate-blue-100 dark:bg-slate-blue-900/50 px-1 py-px text-[0.5rem] font-medium uppercase tracking-wide text-slate-blue-600 dark:text-slate-blue-400">Soon</span>
            </span>
            <a
              href="/docs/"
              class:list={[
                "nav-link inline-flex items-center gap-1.5 transition-colors",
                currentPath.startsWith("/docs") && currentPath !== "/docs/api" && !currentPath.startsWith("/docs/cli")
                  ? "text-foreground font-semibold"
                  : "text-muted-foreground hover:text-slate-blue-700 dark:hover:text-slate-blue-300",
              ]}>
              Docs
            </a>
          </nav>
        </div>
        <div class="flex items-center gap-2">
          {enableSearch && <SearchDialog client:idle meiliUrl={meiliUrl} meiliSearchKey={meiliSearchKey} />}
          <a
            href="https://github.com/chris-c-thomas/LexBuild"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-foreground inline-flex h-9 w-9 items-center justify-center rounded-md transition-colors"
            aria-label="GitHub repository">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z">
              </path>
            </svg>
          </a>
          <ThemeToggle client:load />
        </div>
      </div>
    </header>
    {
      showSidebar ? (
        <div class="flex">
          <Sidebar client:load sourceId={source!} currentPath={currentPath} />
          <main id="main-content" class="bg-background dark:bg-background min-w-0 flex-1 px-4 py-6 sm:px-6 lg:px-8">
            <slot />
          </main>
        </div>
      ) : source ? (
        <main id="main-content" class="bg-background dark:bg-background mx-auto max-w-5xl px-4 py-6 sm:px-6 lg:px-8">
          <slot />
        </main>
      ) : (
        <main id="main-content">
          <slot />
        </main>
      )
    }
    <footer class="border-border text-muted-foreground border-t py-6 text-sm">
      <div class="mx-auto flex max-w-7xl items-center justify-between px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-2">
          <svg
            class="text-slate-blue-800 dark:text-slate-blue-500 h-5 w-5"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.75"
            stroke-linecap="round"
            stroke-linejoin="round">
            <path
              d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z">
            </path><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"></path><path
              d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65">
            </path>
          </svg>
          <span class="font-display text-slate-blue-800 dark:text-slate-blue-200 font-semibold">LexBuild</span>
          <span class="text-muted-foreground">&mdash;</span>
          <span class="text-ink-muted">U.S. Legal Text as Structured Markdown · 2026</span>
        </div>
        <nav class="hidden items-center gap-6 sm:flex">
          <a href="/docs/cli/installation" class="hover:text-slate-blue-700 dark:hover:text-slate-blue-300 transition-colors">
            CLI
          </a>
          <a href="/docs/api" class="hover:text-slate-blue-700 dark:hover:text-slate-blue-300 transition-colors">API</a>
          <span class="inline-flex items-center gap-1.5 text-muted-foreground/50 cursor-default select-none" aria-disabled="true">
            MCP
            <span class="rounded bg-slate-blue-100 dark:bg-slate-blue-900/50 px-1.5 py-0.5 text-[0.625rem] font-medium uppercase tracking-wide text-slate-blue-600 dark:text-slate-blue-400">Soon</span>
          </span>
          <a href="/docs/" class="hover:text-slate-blue-700 dark:hover:text-slate-blue-300 transition-colors">Docs</a>
          <a
            href="https://github.com/chris-c-thomas/LexBuild"
            target="_blank"
            rel="noopener noreferrer"
            class="text-muted-foreground hover:text-slate-blue-700 dark:hover:text-slate-blue-300 inline-flex items-center transition-colors"
            aria-label="GitHub repository">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path
                d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12Z">
              </path>
            </svg>
          </a>
        </nav>
      </div>
    </footer>
  </body>
</html>
