---
import "@/styles/global.css";
import ThemeToggle from "@/components/ui/ThemeToggle";
import { Sidebar } from "@/components/sidebar/Sidebar";
import { MobileNav } from "@/components/sidebar/MobileNav";
import { SearchDialog } from "@/components/search/SearchDialog";
import type { SourceId } from "@/lib/types";

interface Props {
  title: string;
  description?: string;
  source?: SourceId;
}

const { title, description = "U.S. legal code as structured Markdown — LexBuild", source } = Astro.props;
const siteUrl = import.meta.env.SITE_URL ?? "https://lexbuild.dev";
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const currentPath = Astro.url.pathname;
const enableSearch = (import.meta.env.ENABLE_SEARCH ?? "false") === "true";
const meiliUrl = import.meta.env.MEILI_URL ?? "http://127.0.0.1:7700";
const meiliSearchKey = import.meta.env.MEILI_SEARCH_KEY ?? "";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} | LexBuild</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <!-- Prevent flash of wrong theme -->
    <script is:inline>
      (function () {
        const theme = localStorage.getItem("theme");
        if (theme === "dark" || (!theme && matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground antialiased">
    <header class="sticky top-0 z-50 border-b border-border bg-background/95 backdrop-blur supports-[backdrop-filter]:bg-background/60">
      <div class="mx-auto flex h-14 items-center justify-between px-4 sm:px-6 lg:px-8">
        <div class="flex items-center gap-6">
          <MobileNav client:load source={source} currentPath={currentPath} />
          <a href="/" class="text-lg font-bold text-foreground">
            LexBuild
          </a>
          <nav class="hidden items-center gap-4 text-sm font-medium lg:flex">
            <a
              href="/usc"
              class:list={["transition-colors hover:text-foreground", source === "usc" ? "text-foreground" : "text-muted-foreground"]}
            >
              U.S. Code
            </a>
            <a
              href="/ecfr"
              class:list={["transition-colors hover:text-foreground", source === "ecfr" ? "text-foreground" : "text-muted-foreground"]}
            >
              eCFR
            </a>
          </nav>
        </div>
        <div class="flex items-center gap-2">
          {enableSearch && (
            <SearchDialog client:idle meiliUrl={meiliUrl} meiliSearchKey={meiliSearchKey} />
          )}
          <ThemeToggle client:load />
        </div>
      </div>
    </header>
    {source ? (
      <div class="flex">
        <Sidebar client:load sourceId={source} currentPath={currentPath} />
        <main class="min-w-0 flex-1 px-4 py-6 sm:px-6 lg:px-8">
          <slot />
        </main>
      </div>
    ) : (
      <main class="mx-auto max-w-7xl px-4 py-6 sm:px-6 lg:px-8">
        <slot />
      </main>
    )}
    <footer class="border-t border-border py-6 text-center text-sm text-muted-foreground">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        LexBuild &mdash; U.S. legal text as structured Markdown for AI/RAG
      </div>
    </footer>
  </body>
</html>
