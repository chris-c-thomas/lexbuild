---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ErrorPage from "@/components/ErrorPage.astro";
import type { PageSEO } from "@/lib/types";

const siteUrl = import.meta.env.SITE_URL ?? "https://lexbuild.dev";
const seo: PageSEO = {
  title: "405 Method Not Allowed",
  description: "LexBuild content is read-only. If you're seeing this unexpectedly, check your request configuration.",
  canonicalUrl: `${siteUrl}/405`,
  ogType: "website",
  ogImage: `${siteUrl}/og-image.png`,
  robots: "noindex",
  jsonLd: { "@type": "WebPage", name: "Method Not Allowed" },
};
---

<BaseLayout seo={seo}>
  <ErrorPage
    status={405}
    title="Method Not Allowed"
    description="LexBuild content is read-only. If you're seeing this unexpectedly, check your request configuration."
  />
</BaseLayout>
