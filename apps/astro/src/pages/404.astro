---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="Not Found" description="Page not found.">
  <div class="mx-auto max-w-7xl flex flex-col items-center justify-center px-4 py-24 text-center sm:px-6 lg:px-8">
    <h1 class="text-6xl font-bold text-slate-blue-300 dark:text-slate-blue-700">404</h1>
    <p class="mt-4 text-lg text-muted-foreground">Page not found.</p>
    <a
      href="/"
      class="mt-6 inline-flex items-center gap-1.5 text-sm font-medium text-slate-blue-600 hover:text-slate-blue-700 dark:text-slate-blue-400 dark:hover:text-slate-blue-300 transition-colors"
    >
      &larr; Back to home
    </a>
  </div>
</BaseLayout>
