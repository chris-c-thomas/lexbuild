---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContentViewer from "@/components/content/ContentViewer";
import FrontmatterPanel from "@/components/content/FrontmatterPanel.astro";
import BreadcrumbNav from "@/components/content/BreadcrumbNav.astro";
import { CopyButton } from "@/components/content/CopyButton";
import { DownloadButton } from "@/components/content/DownloadButton";
import { resolveRoute, getMonthName } from "@/lib/routes";
import { getFile } from "@/lib/content";
import { getHighlightedHtml } from "@/lib/highlight";
import { renderMarkdown } from "@/lib/markdown";
import { parseFrontmatter } from "@/lib/frontmatter";
import { getFrYear, getFrMonthDocuments } from "@/lib/nav";
import type { SourceId, ContentFrontmatter, PageSEO } from "@/lib/types";
import { toTitleCase } from "@/lib/utils";
import { buildPageSEO } from "@/lib/seo";

const SOURCE_ID: SourceId = "fr";
const { slug } = Astro.params;

const route = resolveRoute(SOURCE_ID, slug?.split("/"));
if (!route) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=31536000, stale-while-revalidate=86400",
);

const siteUrl = import.meta.env.SITE_URL ?? "https://lexbuild.dev";

// Document type badge colors
const TYPE_COLORS: Record<string, string> = {
  rule: "bg-emerald-100 text-emerald-800 dark:bg-emerald-900/30 dark:text-emerald-400",
  proposed_rule: "bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-400",
  notice: "bg-sky-100 text-sky-800 dark:bg-sky-900/30 dark:text-sky-400",
  presidential_document: "bg-purple-100 text-purple-800 dark:bg-purple-900/30 dark:text-purple-400",
};
const TYPE_LABELS: Record<string, string> = {
  rule: "Rule",
  proposed_rule: "Proposed Rule",
  notice: "Notice",
  presidential_document: "Presidential",
};

let pageTitle = "";
let pageDescription = "";
let seo: PageSEO;

// Content data (only for document pages)
let frontmatter: ContentFrontmatter | null = null;
let body = "";
let rawYaml = "";
let highlightedSource = "";
let renderedHtml = "";

// Index data (for year/month pages)
let indexContent: { type: "year" | "month"; html: string } | null = null;
let yearData: Awaited<ReturnType<typeof getFrYear>> = null;
let monthDocs: Awaited<ReturnType<typeof getFrMonthDocuments>> = [];

if (route.granularity === "year") {
  // ── Year index: show month cards ──
  const yearNum = parseInt(route.segments["year"] ?? "0", 10);
  yearData = await getFrYear(yearNum);

  if (!yearData || yearData.months.length === 0) {
    return new Response(null, { status: 404, statusText: "Not found" });
  }

  pageTitle = `Federal Register — ${yearNum}`;
  pageDescription = `${yearData.documentCount.toLocaleString()} documents across ${yearData.months.length} month${yearData.months.length !== 1 ? "s" : ""}`;

  seo = {
    title: pageTitle,
    description: `${yearData.documentCount.toLocaleString()} Federal Register documents from ${yearNum}.`,
    canonicalUrl: new URL(route.canonicalUrl, siteUrl).href,
    ogType: "website",
    ogImage: `${siteUrl}/og-image.png`,
    jsonLd: {
      "@type": "CollectionPage",
      name: pageTitle,
      url: new URL(route.canonicalUrl, siteUrl).href,
    },
  };

  indexContent = { type: "year", html: "" };
} else if (route.granularity === "month") {
  // ── Month index: show document list ──
  const yearNum = parseInt(route.segments["year"] ?? "0", 10);
  const monthNum = parseInt(route.segments["month"] ?? "0", 10);
  monthDocs = await getFrMonthDocuments(yearNum, monthNum);

  if (monthDocs.length === 0) {
    return new Response(null, { status: 404, statusText: "Not found" });
  }

  const monthName = getMonthName(monthNum);
  pageTitle = `Federal Register — ${monthName} ${yearNum}`;
  pageDescription = `${monthDocs.length.toLocaleString()} documents`;

  seo = {
    title: pageTitle,
    description: `${monthDocs.length.toLocaleString()} Federal Register documents from ${monthName} ${yearNum}.`,
    canonicalUrl: new URL(route.canonicalUrl, siteUrl).href,
    ogType: "website",
    ogImage: `${siteUrl}/og-image.png`,
    jsonLd: {
      "@type": "CollectionPage",
      name: pageTitle,
      url: new URL(route.canonicalUrl, siteUrl).href,
    },
  };

  indexContent = { type: "month", html: "" };
} else {
  // ── Document content page ──
  const rawFile = await getFile(route.contentPath);
  if (!rawFile) {
    return new Response(null, { status: 404, statusText: "Not found" });
  }

  const parsed = parseFrontmatter(rawFile);
  frontmatter = parsed.frontmatter;
  body = parsed.body;
  rawYaml = parsed.rawYaml;

  [highlightedSource, renderedHtml] = await Promise.all([
    getHighlightedHtml(route.contentPath, body),
    renderMarkdown(body),
  ]);

  pageTitle = frontmatter.title ? toTitleCase(frontmatter.title) : `FR ${slug}`;

  seo = buildPageSEO({
    source: SOURCE_ID,
    granularity: route.granularity,
    frontmatter,
    breadcrumbs: route.breadcrumbs,
    canonicalUrl: route.canonicalUrl,
    siteUrl,
  });
}

const fullFileContent = rawYaml ? `---\n${rawYaml.trim()}\n---\n${body}` : body;
const documentDownloadFilename = `fr-${slug?.replace(/\//g, "-") ?? "content"}.md`;

// Group month docs by publication date (computed in frontmatter to avoid TS generics in template)
const docsByDate: Array<{ date: string; docs: typeof monthDocs }> = [];
if (monthDocs.length > 0) {
  const dateMap = new Map<string, typeof monthDocs>();
  for (const doc of monthDocs) {
    const existing = dateMap.get(doc.publication_date);
    if (existing) {
      existing.push(doc);
    } else {
      dateMap.set(doc.publication_date, [doc]);
    }
  }
  for (const [date, docs] of dateMap) {
    docsByDate.push({ date, docs });
  }
  // Most recent dates first; undated (YYYY-MM) groups go last
  docsByDate.sort((a, b) => {
    const aFull = a.date.length === 10;
    const bFull = b.date.length === 10;
    if (aFull && !bFull) return -1;
    if (!aFull && bFull) return 1;
    return b.date.localeCompare(a.date);
  });
}
---

<BaseLayout seo={seo!} source={SOURCE_ID}>
  <BreadcrumbNav
    breadcrumbs={route.breadcrumbs}
    currentPageName={frontmatter?.section_name ? toTitleCase(frontmatter.section_name) : undefined}
  />

  {
    route.granularity === "year" && yearData ? (
      <div class="flex flex-col gap-6">
        <div>
          <h1 class="font-display text-slate-blue-800 dark:text-slate-blue-200 text-2xl font-semibold tracking-tight">
            {pageTitle}
          </h1>
          <p class="text-ink-muted mt-1 text-[15px]">{pageDescription}</p>
        </div>

        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {yearData.months
            .sort((a, b) => b.month - a.month)
            .map((m) => {
              const monthStr = String(m.month).padStart(2, "0");
              const monthName = getMonthName(m.month);
              return (
                <a
                  href={`/fr/${yearData!.year}/${monthStr}`}
                  class="border-slate-blue-200 hover:border-slate-blue-400 dark:bg-card dark:border-border dark:hover:border-slate-blue-600 flex flex-col rounded-sm border bg-white p-5 transition-colors"
                >
                  <div class="font-display text-slate-blue-700 dark:text-slate-blue-300 mb-1 text-base font-semibold">
                    {monthName}
                  </div>
                  <div class="text-slate-blue-700 dark:text-slate-blue-400 mt-auto flex flex-wrap items-center gap-2 pt-2 text-xs font-medium">
                    <span>{m.documentCount.toLocaleString()} documents</span>
                    {Object.entries(m.typeCounts)
                      .sort(([, a], [, b]) => b - a)
                      .slice(0, 3)
                      .map(([type, count]) => (
                        <>
                          <span class="bg-slate-blue-300 dark:bg-slate-blue-700 h-3 w-px" />
                          <span>
                            {count} {TYPE_LABELS[type] ?? type}
                          </span>
                        </>
                      ))}
                  </div>
                </a>
              );
            })}
        </div>
      </div>
    ) : route.granularity === "month" && monthDocs.length > 0 ? (
      <div class="flex flex-col gap-6">
        <div>
          <h1 class="font-display text-slate-blue-800 dark:text-slate-blue-200 text-2xl font-semibold tracking-tight">
            {pageTitle}
          </h1>
          <p class="text-ink-muted mt-1 text-[15px]">{pageDescription}</p>
        </div>

        {docsByDate.map((group) => (
          <div>
            {docsByDate.length > 1 || group.date.length === 10 ? (
              <h2 class="text-slate-blue-700 dark:text-slate-blue-400 mb-2 text-sm font-semibold uppercase tracking-wider">
                {group.date.length === 10
                  ? new Date(group.date + "T12:00:00").toLocaleDateString("en-US", {
                      weekday: "long",
                      month: "long",
                      day: "numeric",
                      year: "numeric",
                    })
                  : group.date}
                <span class="text-muted-foreground ml-2 font-normal normal-case tracking-normal">
                  ({group.docs.length} document{group.docs.length !== 1 ? "s" : ""})
                </span>
              </h2>
            ) : null}
            <div class="flex flex-col gap-1">
              {group.docs.map((doc) => (
                <a
                  href={`/fr/${route.segments["year"]}/${route.segments["month"]}/${doc.file}`}
                  class="hover:bg-slate-blue-50 dark:hover:bg-slate-blue-950/30 flex items-start gap-3 rounded-sm px-3 py-2 transition-colors"
                >
                  <span
                    class={`mt-0.5 inline-flex shrink-0 rounded px-1.5 py-0.5 text-[10px] font-semibold uppercase ${TYPE_COLORS[doc.document_type] ?? "bg-gray-100 text-gray-700 dark:bg-gray-800 dark:text-gray-300"}`}
                  >
                    {TYPE_LABELS[doc.document_type] ?? doc.document_type}
                  </span>
                  <span class="text-foreground min-w-0 text-sm leading-snug">{doc.title}</span>
                  <span class="text-muted-foreground mt-0.5 shrink-0 text-xs">
                    {doc.document_number}
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))}
      </div>
    ) : frontmatter ? (
      <div class="flex flex-col gap-6">
        <div class="flex items-start justify-between gap-4">
          <h1 class="font-display text-slate-blue-800 dark:text-slate-blue-200 text-2xl font-semibold tracking-tight">
            {pageTitle}
          </h1>
          <div class="flex shrink-0 gap-2">
            <CopyButton client:load text={fullFileContent} />
            <DownloadButton client:load content={fullFileContent} filename={documentDownloadFilename} />
          </div>
        </div>
        <FrontmatterPanel frontmatter={frontmatter} source={SOURCE_ID} rawYaml={rawYaml} />
        <ContentViewer
          client:load
          rawMarkdown={body}
          rawYaml={rawYaml}
          highlightedSource={highlightedSource}
          renderedHtml={renderedHtml}
          frontmatter={frontmatter}
          granularity={route.granularity}
          downloadFilename={documentDownloadFilename}
        />
      </div>
    ) : null
  }
</BaseLayout>
