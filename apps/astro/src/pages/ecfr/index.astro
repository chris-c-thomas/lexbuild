---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { Card, CardHeader, CardTitle, CardDescription } from "@/components/ui/card";
import { Badge } from "@/components/ui/badge";
import { getSource } from "@/lib/sources";
import { getTitles } from "@/lib/nav";
import { toTitleCase } from "@/lib/utils";

const source = getSource("ecfr");
const titles = await getTitles("ecfr");
---

<BaseLayout title="Code of Federal Regulations" source="ecfr" description="Browse all 50 titles of the eCFR as structured Markdown.">
  <div class="flex flex-col gap-6">
    <div>
      <h1 class="text-3xl font-bold text-slate-blue-800 dark:text-slate-blue-200">{source.name}</h1>
      <p class="mt-2 leading-relaxed text-muted-foreground">{source.description}</p>
    </div>

    {titles.length > 0 ? (
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {titles.map((t) => (
          <a href={`/ecfr/${t.directory}`} class="group">
            <Card size="sm" className="h-full transition-[box-shadow] group-hover:ring-primary/30 group-hover:shadow-sm">
              <CardHeader>
                <CardTitle className="text-lg font-bold text-slate-blue-700 dark:text-slate-blue-400">
                  Title {t.number}
                </CardTitle>
                <CardDescription className="text-sm font-medium text-foreground">
                  {toTitleCase(t.name)}
                </CardDescription>
                <div class="flex flex-wrap gap-2 pt-1">
                  <Badge variant="secondary">{t.chapterCount} chapters</Badge>
                  {t.partCount !== undefined && <Badge variant="secondary">{t.partCount} parts</Badge>}
                  <Badge variant="secondary">{t.sectionCount.toLocaleString()} sections</Badge>
                  <Badge variant="secondary">{t.tokenEstimate.toLocaleString()} tokens</Badge>
                </div>
              </CardHeader>
            </Card>
          </a>
        ))}
      </div>
    ) : (
      <Card>
        <CardHeader className="items-center py-12">
          <CardTitle className="text-muted-foreground">No navigation data available.</CardTitle>
          <CardDescription>Run <code class="text-foreground">scripts/generate-nav.ts</code> after converting content.</CardDescription>
        </CardHeader>
      </Card>
    )}
  </div>
</BaseLayout>
