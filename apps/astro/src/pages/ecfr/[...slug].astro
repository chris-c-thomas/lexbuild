---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ContentViewer from "@/components/content/ContentViewer";
import FrontmatterPanel from "@/components/content/FrontmatterPanel.astro";
import BreadcrumbNav from "@/components/content/BreadcrumbNav.astro";
import HierarchyIndex from "@/components/content/HierarchyIndex.astro";
import { CopyButton } from "@/components/content/CopyButton";
import { DownloadButton } from "@/components/content/DownloadButton";
import { resolveRoute } from "@/lib/routes";
import { getFile } from "@/lib/content";
import { getHighlightedHtml } from "@/lib/highlight";
import { renderMarkdown } from "@/lib/markdown";
import { parseFrontmatter } from "@/lib/frontmatter";
import { getTitleSummary, getTitleNav, getChapterNav } from "@/lib/nav";
import type { SourceId, ContentFrontmatter, PartNav } from "@/lib/types";
import { toTitleCase } from "@/lib/utils";

const SOURCE_ID: SourceId = "ecfr";
const { slug } = Astro.params;

const route = resolveRoute(SOURCE_ID, slug?.split("/"));
if (!route) {
  return new Response(null, { status: 404, statusText: "Not found" });
}

// Cache headers
Astro.response.headers.set(
  "Cache-Control",
  "public, s-maxage=31536000, stale-while-revalidate=86400",
);

// ── Prepare data based on granularity ──

let pageTitle = "";
let pageDescription = "";
let indexChildren: Array<{
  label: string;
  sublabel?: string;
  href: string;
  stats: Array<{ label: string; value: string | number }>;
}> = [];
let indexDescription = "";
let downloadPath: string | undefined;
let downloadFilename: string | undefined;

let frontmatter: ContentFrontmatter | null = null;
let body = "";
let rawYaml = "";
let highlightedSource = "";
let renderedHtml = "";

if (route.granularity === "title") {
  // ── Title index: show chapter cards ──
  const titleDir = route.segments["title"]!;
  const titleSummary = await getTitleSummary(SOURCE_ID, titleDir);
  const titleNav = await getTitleNav(SOURCE_ID, titleDir);

  if (!titleSummary || !titleNav) {
    return new Response(null, { status: 404, statusText: "Not found" });
  }

  const titleName = toTitleCase(titleSummary.name);
  pageTitle = `Title ${titleSummary.number} — ${titleName}`;
  pageDescription = `Title ${titleSummary.number}, ${titleName} — Code of Federal Regulations.`;
  indexDescription = `${titleSummary.chapterCount} chapters, ${titleSummary.partCount ?? 0} parts, ${titleSummary.sectionCount.toLocaleString()} sections`;
  downloadPath = route.contentPath;
  downloadFilename = `ecfr-${titleDir}.md`;

  indexChildren = titleNav.chapters.map((ch) => {
    const partCount = ch.parts?.length ?? 0;
    const sectionCount = ch.parts?.reduce((s, p) => s + p.sections.length, 0) ?? 0;
    return {
      label: `Chapter ${ch.number}`,
      sublabel: ch.name,
      href: `/ecfr/${titleDir}/${ch.directory}`,
      stats: [
        { label: "parts", value: partCount },
        { label: "sections", value: sectionCount },
      ],
    };
  });
} else if (route.granularity === "chapter") {
  // ── Chapter index: show part cards ──
  const titleDir = route.segments["title"]!;
  const chapterDir = route.segments["chapter"]!;
  const titleSummary = await getTitleSummary(SOURCE_ID, titleDir);
  const chapter = await getChapterNav(SOURCE_ID, titleDir, chapterDir);

  if (!titleSummary || !chapter) {
    return new Response(null, { status: 404, statusText: "Not found" });
  }

  const titleName = toTitleCase(titleSummary.name);
  const chapterNumber = chapterDir.replace("chapter-", "");
  const chapterName = toTitleCase(chapter.name);
  pageTitle = `Title ${titleSummary.number}, Chapter ${chapterNumber} — ${chapterName}`;
  pageDescription = `Chapter ${chapterNumber}, ${chapterName}. Title ${titleSummary.number}, ${titleName} — Code of Federal Regulations.`;
  indexDescription = `${chapter.parts?.length ?? 0} parts`;
  downloadPath = route.contentPath;
  downloadFilename = `ecfr-${titleDir}-${chapterDir}.md`;

  indexChildren = (chapter.parts ?? []).map((p) => ({
    label: `Part ${p.number}`,
    sublabel: p.name,
    href: `/ecfr/${titleDir}/${chapterDir}/${p.directory}`,
    stats: [{ label: "sections", value: p.sections.length }],
  }));
} else if (route.granularity === "part") {
  // ── Part index: show section cards ──
  const titleDir = route.segments["title"]!;
  const chapterDir = route.segments["chapter"]!;
  const partDir = route.segments["part"]!;
  const titleSummary = await getTitleSummary(SOURCE_ID, titleDir);
  const chapter = await getChapterNav(SOURCE_ID, titleDir, chapterDir);

  if (!titleSummary || !chapter) {
    return new Response(null, { status: 404, statusText: "Not found" });
  }

  const part: PartNav | undefined = chapter.parts?.find((p) => p.directory === partDir);
  if (!part) {
    return new Response(null, { status: 404, statusText: "Not found" });
  }

  const titleName = toTitleCase(titleSummary.name);
  const partName = toTitleCase(part.name);
  const chapterNumber = chapterDir.replace("chapter-", "");
  pageTitle = `Title ${titleSummary.number}, Part ${part.number} — ${partName}`;
  pageDescription = `Part ${part.number}, ${partName}. Chapter ${chapterNumber}, Title ${titleSummary.number}, ${titleName} — Code of Federal Regulations.`;
  indexDescription = `${part.sections.length} sections`;
  downloadPath = route.contentPath;
  downloadFilename = `ecfr-${titleDir}-${chapterDir}-${partDir}.md`;

  indexChildren = part.sections.map((s) => ({
    label: `Section ${s.number}`,
    sublabel: s.name,
    href: `/ecfr/${titleDir}/${chapterDir}/${partDir}/${s.file}`,
    stats: s.status !== "current" ? [{ label: s.status, value: "" }] : [],
  }));
} else {
  // ── Section content page ──
  const rawFile = await getFile(route.contentPath);
  if (!rawFile) {
    return new Response(null, { status: 404, statusText: "Not found" });
  }

  const parsed = parseFrontmatter(rawFile);
  frontmatter = parsed.frontmatter;
  body = parsed.body;
  rawYaml = parsed.rawYaml;

  [highlightedSource, renderedHtml] = await Promise.all([
    getHighlightedHtml(route.contentPath, body),
    renderMarkdown(body),
  ]);

  pageTitle = frontmatter.title ? toTitleCase(frontmatter.title) : `eCFR - ${slug}`;
  const sectionName = frontmatter.section_name ? toTitleCase(frontmatter.section_name) : "";
  const partCtx = frontmatter.part_name
    ? `Part ${frontmatter.part_number}, ${toTitleCase(frontmatter.part_name)}`
    : "";
  pageDescription = `${frontmatter.title_number} CFR § ${frontmatter.section_number ?? ""}${sectionName ? ` — ${sectionName}` : ""}. ${partCtx ? `${partCtx}. ` : ""}Title ${frontmatter.title_number}, ${toTitleCase(frontmatter.title_name)}.`;
}

const isIndexPage = route.granularity !== "section";
const fullFileContent = rawYaml ? `---\n${rawYaml.trim()}\n---\n${body}` : body;
const sectionDownloadFilename = `ecfr-${slug?.replace(/\//g, "-") ?? "content"}.md`;
---

<BaseLayout title={pageTitle} source={SOURCE_ID} description={pageDescription}>
  <BreadcrumbNav
    breadcrumbs={route.breadcrumbs}
    currentPageName={frontmatter?.section_name ? toTitleCase(frontmatter.section_name) : undefined}
  />

  {
    isIndexPage ? (
      <HierarchyIndex
        source={SOURCE_ID}
        granularity={route.granularity}
        heading={pageTitle}
        description={indexDescription}
        children={indexChildren}
        downloadPath={downloadPath}
        downloadFilename={downloadFilename}
      />
    ) : frontmatter ? (
      <div class="flex flex-col gap-6">
        <div class="flex items-start justify-between gap-4">
          <h1 class="font-display text-slate-blue-800 dark:text-slate-blue-200 text-2xl font-semibold tracking-tight">
            {toTitleCase(frontmatter.title)}
          </h1>
          <div class="flex shrink-0 gap-2">
            <CopyButton client:load text={fullFileContent} />
            <DownloadButton
              client:load
              content={fullFileContent}
              filename={sectionDownloadFilename}
            />
          </div>
        </div>
        <FrontmatterPanel frontmatter={frontmatter} source={SOURCE_ID} rawYaml={rawYaml} />
        <ContentViewer
          client:load
          rawMarkdown={body}
          rawYaml={rawYaml}
          highlightedSource={highlightedSource}
          renderedHtml={renderedHtml}
          frontmatter={frontmatter}
          granularity={route.granularity}
          downloadFilename={sectionDownloadFilename}
        />
      </div>
    ) : null
  }
</BaseLayout>
