---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { getSource } from "@/lib/sources";
import { getTitles } from "@/lib/nav";
import { toTitleCase } from "@/lib/utils";
import type { PageSEO } from "@/lib/types";

const source = getSource("usc");
const titles = await getTitles("usc");

const siteUrl = import.meta.env.SITE_URL ?? "https://lexbuild.dev";
const seo: PageSEO = {
  title: "U.S. Code",
  description:
    "Browse all 54 titles of the U.S. Code as structured Markdown. Full text with frontmatter metadata for LLMs, RAG, and semantic search.",
  canonicalUrl: `${siteUrl}/usc`,
  ogType: "website",
  ogImage: `${siteUrl}/og-image.png`,
  jsonLd: [
    {
      "@type": "WebPage",
      name: "U.S. Code",
      url: `${siteUrl}/usc`,
      description: "Browse all 54 titles of the U.S. Code as structured Markdown.",
      isPartOf: { "@type": "WebSite", name: "LexBuild", url: siteUrl },
    },
    {
      "@type": "BreadcrumbList",
      itemListElement: [{ "@type": "ListItem", position: 1, name: "U.S. Code" }],
    },
  ],
};

Astro.response.headers.set("Cache-Control", "public, s-maxage=3600, stale-while-revalidate=86400");
---

<BaseLayout seo={seo} source="usc">
  <div class="flex flex-col gap-6">
    <div>
      <h1 class="font-display text-slate-blue-900 dark:text-slate-blue-200 text-2xl font-semibold tracking-tight">
        {source.name}
      </h1>
      <p class="text-ink-muted mt-2 text-[15px] leading-relaxed">{source.description}</p>
    </div>

    {
      titles.length > 0 ? (
        <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
          {titles.map((t) => (
            <a
              href={`/usc/${t.directory}`}
              class="border-slate-blue-200 hover:border-slate-blue-400 dark:bg-card dark:border-border dark:hover:border-slate-blue-600 flex flex-col rounded-sm border bg-white p-5 transition-colors">
              <div class="font-display text-slate-blue-800 dark:text-slate-blue-300 mb-1 text-base font-semibold">
                Title {t.number}
              </div>
              <div class="text-foreground text-sm">{toTitleCase(t.name)}</div>
              <div class="text-slate-blue-700 dark:text-slate-blue-400 mt-auto flex flex-wrap items-center gap-2 pt-2 text-xs font-medium">
                <span>{t.chapterCount} chapters</span>
                <span class="bg-slate-blue-300 dark:bg-slate-blue-700 h-3 w-px" />
                <span>{t.sectionCount.toLocaleString()} sections</span>
                <span class="bg-slate-blue-300 dark:bg-slate-blue-700 h-3 w-px" />
                <span>{t.tokenEstimate.toLocaleString()} tokens</span>
              </div>
            </a>
          ))}
        </div>
      ) : (
        <div class="border-slate-blue-200 dark:bg-card dark:border-border rounded-sm border bg-white p-12 text-center">
          <p class="text-muted-foreground font-medium">No navigation data available.</p>
          <p class="text-muted-foreground mt-1 text-sm">
            Run <code class="text-foreground">scripts/generate-nav.ts</code> after converting content.
          </p>
        </div>
      )
    }
  </div>
</BaseLayout>
