<script>
  document.querySelectorAll("[data-sample-tabs]").forEach((panel) => {
    const buttons = panel.querySelectorAll(".sample-tab");
    const contents = panel.querySelectorAll("[data-tab-content]");
    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.dataset.tab;
        buttons.forEach((b) => b.classList.toggle("active", b.dataset.tab === target));
        contents.forEach((c) => {
          c.style.display = c.dataset.tabContent === target ? "" : "none";
        });
      });
    });
  });
</script>

