---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SOURCES } from "@/lib/sources";

const sources = Object.values(SOURCES);
---

<BaseLayout title="LexBuild" description="U.S. legal text as structured Markdown">
  <section class="bg-surface border-b border-border-base bg-grid-pattern">
    <div class="max-w-[1200px] mx-auto px-6 text-center py-12 sm:py-16">
      <div class="inline-flex items-center justify-center w-14 h-14 mb-5 text-slate-blue-600">
        <svg
          class="w-11 h-11"
          viewBox="0 0 48 48"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <rect x="6" y="4" width="36" height="40" rx="3"></rect>
          <line x1="14" y1="14" x2="34" y2="14"></line>
          <line x1="14" y1="20" x2="30" y2="20"></line>
          <line x1="14" y1="26" x2="34" y2="26"></line>
          <line x1="14" y1="32" x2="26" y2="32"></line>
          <path d="M24 4 V0"></path>
          <circle cx="24" cy="9" r="1.5" fill="currentColor" stroke="none"></circle>
        </svg>
      </div>
      <h1
        class="font-display text-[clamp(2.5rem,5vw,3.5rem)] font-semibold tracking-tight leading-tight mb-2 text-slate-blue-950"
      >
        LexBuild
      </h1>
      <p class="font-display text-xl text-slate-blue-700 mb-4 tracking-tight">
        U.S. Legal Text as Structured Markdown
      </p>
      <p class="text-ink-muted max-w-[796px] mx-auto mb-7 text-[15px] leading-relaxed">
        An open-source CLI toolchain and searchable web resource for U.S. federal and state legal
        texts. Convert official source XML into structured Markdown built for LLMs, agentic workflows, RAG pipelines, semantic search, and personal knowledge bases.
      </p>
      <div
        class="flex items-center justify-center gap-2 text-[14px] text-slate-blue-600 font-medium mb-8"
      >
        <span class="whitespace-nowrap">290k+ Sections</span>
        <div class="w-px h-3.5 bg-slate-blue-500"></div>
        <span class="whitespace-nowrap">Update Daily</span>
        <div class="w-px h-3.5 bg-slate-blue-500"></div>

        <span class="whitespace-nowrap">Open Source</span>
      </div>
      <div class="flex items-center justify-center gap-3 flex-wrap">
        <a
          href="#quickstart"
          class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-md bg-slate-blue-600 text-white border border-slate-blue-700 hover:bg-slate-blue-700 hover:border-slate-blue-700 transition-all duration-150 cursor-pointer"
        >
          CLI Quick Start
          <svg
            class="w-4 h-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
        <a
          href="https://github.com/chris-c-thomas/LexBuild"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-md bg-white text-slate-blue-700 border border-slate-blue-200 hover:border-slate-blue-400 hover:bg-slate-blue-50 transition-all duration-150 cursor-pointer"
