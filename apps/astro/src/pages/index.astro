---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SOURCES } from "@/lib/sources";
import { highlightYaml, highlightMarkdown } from "@/lib/shiki";
import type { PageSEO } from "@/lib/types";

const sources = Object.values(SOURCES);

const sampleYaml = `---
title: "17 USC § 107 - Limitations on exclusive rights: Fair use"
title_number: 17
title_name: "COPYRIGHTS"
section_number: "107"
section_name: "Limitations on exclusive rights: Fair use"
chapter_number: 1
chapter_name: "Subject Matter and Scope of Copyright"
positive_law: true
currency: "119-73"
last_updated: "2025-12-03"
format_version: "1.1.0"
generator: "lexbuild@0.0.0"
source_credit: "(Pub. L. 94-553, title I, § 101, Oct. 19, 1976, 90 Stat. 2546; Pub. L. 101-650, title VI, § 607, Dec. 1, 1990, 104 Stat. 5132; Pub. L. 102-492, Oct. 24, 1992, 106 Stat. 3145.)"
---`;

const samplePreviewFields = [
  { label: "Identifier", value: "/us/usc/t17/s107" },
  { label: "Currency", value: "119-73" },
  { label: "Positive Law", value: "Yes" },
  { label: "Updated", value: "2025-12-03" },
  { label: "Chapter", value: "1 — Subject Matter and Scope of Copyright" },
];

const sampleMarkdown = `# § 107. Limitations on exclusive rights: Fair use

Notwithstanding the provisions of sections 106 and 106A, the fair use of a copyrighted work, including such use by reproduction in copies or phonorecords or by any other means specified by that section, for purposes such as criticism, comment, news reporting, teaching (including multiple copies for classroom use), scholarship, or research, is not an infringement of copyright. In determining whether the use made of a work in any particular case is a fair use the factors to be considered shall include—

**(1)** the purpose and character of the use, including whether such use is of a commercial nature or is for nonprofit educational purposes;

**(2)** the nature of the copyrighted work;

**(3)** the amount and substantiality of the portion used in relation to the copyrighted work as a whole; and

**(4)** the effect of the use upon the potential market for or value of the copyrighted work.

The fact that a work is unpublished shall not itself bar a finding of fair use if such finding is made upon consideration of all the above factors.

---

**Source Credit**: (Pub. L. 94–553, title I, § 101, Oct. 19, 1976, 90 Stat. 2546; Pub. L. 101–650, title VI, § 607, Dec. 1, 1990, 104 Stat. 5132; Pub. L. 102–492, Oct. 24, 1992, 106 Stat. 3145.)`;

const highlightedYaml = await highlightYaml(sampleYaml);
const highlightedMarkdown = await highlightMarkdown(sampleMarkdown);

const siteUrl = import.meta.env.SITE_URL ?? "https://lexbuild.dev";
const seo: PageSEO = {
  title: "LexBuild — U.S. Law as Structured Markdown",
  rawTitle: true,
  description:
    "U.S. federal law and regulations as structured Markdown. Browse, search, copy, and download the U.S. Code and Code of Federal Regulations for LLMs, RAG pipelines, and semantic search.",
  canonicalUrl: siteUrl,
  ogType: "website",
  ogImage: `${siteUrl}/og-image.png`,
  jsonLd: {
    "@type": "WebSite",
    name: "LexBuild",
    url: siteUrl,
    description:
      "U.S. federal law and regulations as structured Markdown for LLMs, RAG, and semantic search.",
  },
};
---

<BaseLayout seo={seo}>
  <section class="bg-surface border-border-base bg-grid-pattern border-b">
    <div class="mx-auto max-w-[1200px] px-6 py-12 text-center sm:py-16">
      <div
        class="text-slate-blue-900 dark:text-slate-blue-400 inline-flex h-14 w-14 items-center justify-center"
      >
        <svg
          class="h-11 w-11"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="m12.83 2.18a2 2 0 0 0-1.66 0L2.6 6.08a1 1 0 0 0 0 1.83l8.58 3.91a2 2 0 0 0 1.66 0l8.58-3.9a1 1 0 0 0 0-1.83Z"
          ></path><path d="m22 17.65-9.17 4.16a2 2 0 0 1-1.66 0L2 17.65"></path><path
            d="m22 12.65-9.17 4.16a2 2 0 0 1-1.66 0L2 12.65"></path></svg
        >
      </div>
      <h1
        class="font-display text-slate-blue-900 dark:text-slate-blue-100 mb-2 text-[clamp(2.5rem,5vw,3.5rem)] leading-tight font-semibold tracking-tight"
      >
        LexBuild
      </h1>
      <p
        class="font-display text-slate-blue-700 dark:text-slate-blue-300 mb-6 text-2xl font-medium tracking-tight"
      >
        U.S. Legal Text as Structured Markdown
      </p>
      <p class="text-ink-muted mx-auto mb-7 max-w-[796px] text-[15px] leading-relaxed">
        An open-source CLI toolchain and searchable web resource for U.S. federal and state legal
        texts. Convert official source XML into structured Markdown built for LLMs, agentic
        workflows, RAG pipelines, semantic search, and personal knowledge bases.
      </p>
      <div
        class="text-slate-blue-600 dark:text-slate-blue-400 mb-8 flex items-center justify-center gap-2 text-[14px] font-medium"
      >
        <span class="whitespace-nowrap">290k+ Sections</span>
        <div class="bg-slate-blue-500 dark:bg-slate-blue-600 h-3.5 w-px"></div>
        <span class="whitespace-nowrap">Updated Daily</span>
        <div class="bg-slate-blue-500 dark:bg-slate-blue-600 h-3.5 w-px"></div>

        <span class="whitespace-nowrap">Open Source</span>
      </div>
      <div class="flex flex-wrap items-center justify-center gap-3">
        <a
          href="#quickstart"
          class="bg-slate-blue-600 border-slate-blue-700 hover:bg-slate-blue-700 hover:border-slate-blue-700 inline-flex cursor-pointer items-center gap-2 rounded-sm border px-5 py-2.5 text-sm font-semibold text-white transition-all duration-150"
        >
          CLI Quick Start
          <svg
            class="h-4 w-4"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M19 9l-7 7-7-7"></path>
          </svg>
        </a>
        <a
          href="https://github.com/chris-c-thomas/LexBuild"
          target="_blank"
          rel="noopener"
          class="text-slate-blue-900 border-slate-blue-300 hover:border-slate-blue-500 hover:bg-slate-blue-50 dark:bg-slate-blue-800 dark:text-slate-blue-200 dark:border-slate-blue-700 dark:hover:border-slate-blue-500 dark:hover:bg-slate-blue-800 inline-flex cursor-pointer items-center gap-2 rounded-sm border bg-white px-5 py-2.5 text-sm font-semibold transition-all duration-150"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
            ></path>
          </svg>
          View on GitHub
        </a>
      </div>
    </div>
  </section>

  <section id="quickstart" class="border-border-base border-b py-14">
    <div class="mx-auto max-w-3xl px-6">
      <div class="mb-6">
        <h2
          class="font-display text-slate-blue-900 dark:text-slate-blue-200 mb-1 text-xl font-semibold tracking-tight"
        >
          CLI Quick Start
        </h2>
        <p class="text-ink-muted text-[15px]">
          No complex configuration required. Advanced CLI options are available.
        </p>
      </div>
      <div
        class="bg-slate-blue-50 border-slate-blue-200 dark:bg-card dark:border-border rounded-sm border p-5 sm:p-6"
      >
        <div class="mb-3 flex flex-col gap-1.5">
          <span
            class="text-slate-blue-700 border-slate-blue-300 bg-slate-blue-100 dark:text-slate-blue-300 dark:border-slate-blue-600 dark:bg-slate-blue-900 self-start rounded-sm border px-2 py-0.5 font-mono text-[11px] font-medium tracking-wider uppercase"
            >USC</span
          >
          <span class="text-[15px] font-normal"
            >Download all 54 Titles of the U.S. Code directly from the source <a
              href="https://uscode.house.gov/download/download.shtml"
              target="_blank"
              rel="noopener"
              class="text-slate-blue-600 hover:text-slate-blue-800 dark:text-slate-blue-400 dark:hover:text-slate-blue-200 font-medium"
              >XML
            </a> provided by the <a
              href="https://uscode.house.gov/"
              target="_blank"
              rel="noopener"
              class="text-slate-blue-600 hover:text-slate-blue-800 dark:text-slate-blue-400 dark:hover:text-slate-blue-200 font-medium"
              >OLRC</a
            > and convert into per-section Markdown files.</span
          >
        </div>
        <div
          class="bg-slate-blue-950 overflow-x-auto rounded-sm p-4 font-mono text-[13px] leading-relaxed text-[#d4dce4]"
        >
          <div>
            <span class="text-slate-blue-400">$</span>
            <span class="text-white">npx @lexbuild/cli download-usc</span>
            <span class="text-putty-300">--all</span>
          </div>
          <div>
            <span class="text-slate-blue-400">$</span>
            <span class="text-white">npx @lexbuild/cli convert-usc</span>
            <span class="text-putty-300">--all</span>
          </div>
        </div>
      </div>
      <div class="mt-5 flex justify-center">
        <a
          href="https://github.com/chris-c-thomas/LexBuild/blob/main/docs/reference/cli-reference.md"
          class="text-slate-blue-800 border-slate-blue-300 hover:border-slate-blue-500 hover:bg-slate-blue-50 dark:bg-slate-blue-900 dark:text-slate-blue-200 dark:border-slate-blue-700 dark:hover:border-slate-blue-500 dark:hover:bg-slate-blue-800 inline-flex cursor-pointer items-center gap-2 rounded-sm border bg-white px-5 py-2.5 text-sm font-semibold transition-all duration-150"
        >
          <svg
            class="h-4 w-4"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <polyline points="4 17 10 11 4 5"></polyline>
            <line x1="12" y1="19" x2="20" y2="19"></line>
          </svg>
          Full CLI Docs
        </a>
      </div>
    </div>
  </section>

  <section
    id="sources"
    class="bg-slate-blue-50 dark:bg-slate-blue-950/50 border-border-base border-b py-14"
  >
    <div class="mx-auto max-w-4xl px-6">
      <div class="mb-6">
        <h2
          class="font-display text-slate-blue-900 dark:text-slate-blue-200 mb-1 text-xl font-semibold tracking-tight"
        >
          Browse Sources
        </h2>
        <p class="text-ink-muted text-[15px]">
          Explore U.S. federal law and regulations as structured Markdown, no CLI required. Browse,
          copy, or download entire titles, chapters, parts, or sections straight from the browser.
        </p>
      </div>
      <div class="grid gap-6 sm:grid-cols-2">
        {
          sources.map((source) => (
            <a
              href={source.basePath}
              class="group border-border bg-card hover:border-slate-blue-400 dark:hover:border-slate-blue-600 rounded-sm border p-6 transition-[border-color,box-shadow] hover:shadow-md"
            >
              <div class="flex items-center gap-3">
                <span class="text-slate-blue-600 dark:text-slate-blue-400 text-xs font-bold tracking-wider">
                  {source.shortName}
                </span>
                <span class="bg-slate-blue-200 dark:bg-slate-blue-800 h-px flex-1" />
              </div>
              <h2 class="text-foreground group-hover:text-slate-blue-700 dark:group-hover:text-slate-blue-300 mt-3 font-sans text-xl font-semibold transition-colors">
                {source.name}
              </h2>
              <p class="text-muted-foreground mt-2 text-sm leading-relaxed">{source.description}</p>
              <div class="mt-4 flex items-center justify-between">
                <div class="text-slate-blue-700 dark:text-slate-blue-400 flex items-center gap-2 text-xs font-medium">
                  <span>{source.titleCount.toLocaleString()} titles</span>
                  <span class="bg-slate-blue-300 dark:bg-slate-blue-700 h-3 w-px" />
                  <span>{source.chapterCount.toLocaleString()} chapters</span>
                  {source.partCount && (
                    <>
                      <span class="bg-slate-blue-300 dark:bg-slate-blue-700 h-3 w-px" />
                      <span>{source.partCount.toLocaleString()} parts</span>
                    </>
                  )}
                  <span class="bg-slate-blue-300 dark:bg-slate-blue-700 h-3 w-px" />
                  <span>{source.sectionCount.toLocaleString()} sections</span>
                </div>
                <span class="text-slate-blue-400 dark:text-slate-blue-300 text-sm transition-transform duration-200 group-hover:translate-x-1 group-hover:scale-125">
                  &rarr;
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section
    id="sample-output"
    class="dark:bg-background border-border-base border-b bg-[#FAFAFA] py-14"
  >
    <div class="mx-auto max-w-4xl px-6">
      <div class="mb-6">
        <h2
          class="font-display text-slate-blue-900 dark:text-slate-blue-200 mb-1 text-xl font-semibold tracking-tight"
        >
          Sample Output
        </h2>
        <p class="text-ink-muted text-[15px]">
          Every section includes YAML frontmatter and preserves statutory structure.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-4">
        <!-- Frontmatter panel -->
        <div class="sample-panel" data-sample-tabs>
          <div class="sample-toolbar">
            <div class="sample-tabs-list">
              <button class="sample-tab active" data-tab="yaml" type="button">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path
                    d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"
                  ></path><path d="M16 17H8"></path></svg
                >
                YAML
              </button>
              <button class="sample-tab" data-tab="preview" type="button">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"
                  ></path><circle cx="12" cy="12" r="3"></circle></svg
                >
                Preview
              </button>
            </div>
          </div>
          <div class="sample-content" data-tab-content="yaml">
            <div class="sample-shiki"><Fragment set:html={highlightedYaml} /></div>
          </div>
          <div class="sample-content" data-tab-content="preview" style="display:none;">
            <dl class="sample-preview-grid">
              {
                samplePreviewFields.map((field) => (
                  <div class="sample-preview-cell">
                    <dt class="sample-preview-label">{field.label}</dt>
                    <dd class="sample-preview-value">{field.value}</dd>
                  </div>
                ))
              }
            </dl>
            <dl class="sample-preview-full">
              <dt class="sample-preview-label">Source</dt>
              <dd class="sample-preview-value">
                (Pub. L. 94-553, title I, § 101, Oct. 19, 1976, 90 Stat. 2546; Pub. L. 101-650,
                title VI, § 607, Dec. 1, 1990, 104 Stat. 5132; Pub. L. 102-492, Oct. 24, 1992, 106
                Stat. 3145.)
              </dd>
            </dl>
          </div>
        </div>

        <!-- Content panel -->
        <div class="sample-panel" data-sample-tabs>
          <div class="sample-toolbar">
            <div class="sample-tabs-list">
              <button class="sample-tab active" data-tab="markdown" type="button">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z"></path><path
                    d="M14 2v4a2 2 0 0 0 2 2h4"></path><path d="M10 9H8"></path><path d="M16 13H8"
                  ></path><path d="M16 17H8"></path></svg
                >
                Markdown
              </button>
              <button class="sample-tab" data-tab="rendered" type="button">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  width="14"
                  height="14"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  ><path
                    d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0"
                  ></path><circle cx="12" cy="12" r="3"></circle></svg
                >
                Preview
              </button>
            </div>
          </div>
          <div class="sample-content sample-content-scroll" data-tab-content="markdown">
            <div class="sample-shiki"><Fragment set:html={highlightedMarkdown} /></div>
          </div>
          <div
            class="sample-content sample-content-scroll"
            data-tab-content="rendered"
            style="display:none;"
          >
            <div class="prose prose-zinc dark:prose-invert max-w-none p-4 text-sm">
              <h1>§ 107. Limitations on exclusive rights: Fair use</h1>
              <p>
                Notwithstanding the provisions of sections 106 and 106A, the fair use of a
                copyrighted work, including such use by reproduction in copies or phonorecords or by
                any other means specified by that section, for purposes such as criticism, comment,
                news reporting, teaching (including multiple copies for classroom use), scholarship,
                or research, is not an infringement of copyright. In determining whether the use
                made of a work in any particular case is a fair use the factors to be considered
                shall include—
              </p>
              <p>
                <strong>(1)</strong> the purpose and character of the use, including whether such use
                is of a commercial nature or is for nonprofit educational purposes;
              </p>
              <p><strong>(2)</strong> the nature of the copyrighted work;</p>
              <p>
                <strong>(3)</strong> the amount and substantiality of the portion used in relation to
                the copyrighted work as a whole; and
              </p>
              <p>
                <strong>(4)</strong> the effect of the use upon the potential market for or value of the
                copyrighted work.
              </p>
              <p>
                The fact that a work is unpublished shall not itself bar a finding of fair use if
                such finding is made upon consideration of all the above factors.
              </p>
              <hr />
              <p>
                <strong>Source Credit</strong>: (Pub. L. 94–553, title I, § 101, Oct. 19, 1976, 90
                Stat. 2546; Pub. L. 101–650, title VI, § 607, Dec. 1, 1990, 104 Stat. 5132; Pub. L.
                102–492, Oct. 24, 1992, 106 Stat. 3145.)
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section
    id="packages"
    class="bg-summer-green-50/75 dark:bg-slate-blue-950/50 border-border-base border-b py-14"
  >
    <div class="mx-auto max-w-4xl px-6">
      <div class="mb-6">
        <h2
          class="font-display text-slate-blue-900 dark:text-slate-blue-200 mb-1 text-xl font-semibold tracking-tight"
        >
          Packages
        </h2>
        <p class="text-ink-muted text-[15px]">
          A monorepo of composable packages. Source-specific parsers are separate from the shared
          core.
        </p>
      </div>
      <div class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-4">
        <a
          href="https://www.npmjs.com/package/@lexbuild/core"
          target="_blank"
          rel="noopener"
          class="group border-slate-blue-200 hover:border-slate-blue-400 dark:bg-card dark:border-border dark:hover:border-slate-blue-600 relative flex flex-col rounded-sm border bg-white p-5 transition-colors"
        >
          <svg
            class="text-slate-blue-300 dark:text-slate-blue-600 group-hover:text-slate-blue-500 dark:group-hover:text-slate-blue-400 absolute top-3.5 right-3.5 h-3.5 w-3.5 transition-colors"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline
              points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg
          >
          <div
            class="text-slate-blue-700 dark:text-slate-blue-300 mb-1.5 font-mono text-[13px] font-medium"
          >
            @lexbuild/core
          </div>
          <div class="mb-1 text-[13px] font-semibold">Core Engine</div>
          <p class="text-slate-blue-700 dark:text-slate-blue-400 text-[13px] leading-normal">
            Streaming SAX parser, typed AST, Markdown renderer, YAML frontmatter generation, and
            cross-reference link resolution.
          </p>
          <div
            class="text-summer-green-600 dark:text-summer-green-500 mt-auto pt-2.5 font-mono text-[12px] font-semibold"
          >
            Published
          </div>
        </a>
        <a
          href="https://www.npmjs.com/package/@lexbuild/cli"
          target="_blank"
          rel="noopener"
          class="group border-slate-blue-200 hover:border-slate-blue-400 dark:bg-card dark:border-border dark:hover:border-slate-blue-600 relative flex flex-col rounded-sm border bg-white p-5 transition-colors"
        >
          <svg
            class="text-slate-blue-300 dark:text-slate-blue-600 group-hover:text-slate-blue-500 dark:group-hover:text-slate-blue-400 absolute top-3.5 right-3.5 h-3.5 w-3.5 transition-colors"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline
              points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg
          >
          <div
            class="text-slate-blue-700 dark:text-slate-blue-300 mb-1.5 font-mono text-[13px] font-medium"
          >
