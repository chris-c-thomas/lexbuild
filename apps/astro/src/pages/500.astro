---
/**
 * Astro's SSR error boundary — rendered when an unhandled exception occurs
 * during server-side rendering. Keep imports minimal to avoid cascading
 * failures. If BaseLayout itself ever becomes a failure point, inline a
 * minimal HTML shell here instead.
 */
import BaseLayout from "@/layouts/BaseLayout.astro";
import ErrorPage from "@/components/ErrorPage.astro";
import type { PageSEO } from "@/lib/types";

const siteUrl = import.meta.env.SITE_URL ?? "https://lexbuild.dev";
const seo: PageSEO = {
  title: "500 Internal Server Error",
  description: "An unexpected error occurred. Please try again later.",
  canonicalUrl: `${siteUrl}/500`,
  ogType: "website",
  ogImage: `${siteUrl}/og-image.png`,
  robots: "noindex",
  jsonLd: { "@type": "WebPage", name: "Internal Server Error" },
};
---

<BaseLayout seo={seo}>
  <ErrorPage
    status={500}
    title="Internal Server Error"
    description="An unexpected error occurred. Please try again later."
  />
</BaseLayout>
