---
import BaseLayout from "@/layouts/BaseLayout.astro";
import ErrorPage from "@/components/ErrorPage.astro";
import type { PageSEO } from "@/lib/types";

const siteUrl = import.meta.env.SITE_URL ?? "https://lexbuild.dev";
const seo: PageSEO = {
  title: "503 Service Unavailable",
  description: "The server is undergoing maintenance or is temporarily overloaded. Please try again shortly.",
  canonicalUrl: `${siteUrl}/503`,
  ogType: "website",
  ogImage: `${siteUrl}/og-image.png`,
  robots: "noindex",
  jsonLd: { "@type": "WebPage", name: "Service Unavailable" },
};
---

<BaseLayout seo={seo}>
  <ErrorPage
    status={503}
    title="Service Unavailable"
    description="The server is undergoing maintenance or is temporarily overloaded. Please try again shortly."
  />
</BaseLayout>
