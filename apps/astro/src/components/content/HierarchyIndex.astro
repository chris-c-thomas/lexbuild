---
/**
 * Index page for title, chapter, and part views.
 * Shows child items as cards with stats, plus a download button
 * for the current granularity's .md file (if it exists).
 */
import { Button } from "@/components/ui/button";
import { toTitleCase } from "@/lib/utils";
import { getFile } from "@/lib/content";
import type { SourceId, Granularity } from "@/lib/types";
import { Download } from "lucide-react";

interface ChildItem {
  label: string;
  sublabel?: string;
  href: string;
  stats: Array<{ label: string; value: string | number }>;
}

interface Props {
  source: SourceId;
  granularity: Granularity;
  heading: string;
  description?: string;
  children: ChildItem[];
  downloadPath?: string;
  downloadFilename?: string;
}

const { source, granularity, heading, description, children, downloadPath, downloadFilename } = Astro.props;

let downloadAvailable = false;
let downloadContent: string | null = null;
if (downloadPath) {
  downloadContent = await getFile(downloadPath);
  downloadAvailable = downloadContent !== null;
}

const granularityLabel = granularity === "title" ? "Title" : granularity === "chapter" ? "Chapter" : "Part";
---

<div class="flex flex-col gap-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="font-display text-2xl font-semibold tracking-tight text-slate-blue-800 dark:text-slate-blue-200">{toTitleCase(heading)}</h1>
      {description && <p class="mt-1 text-ink-muted text-[15px]">{description}</p>}
    </div>
    {downloadAvailable && downloadFilename && (
      <a
        href={`data:text/markdown;charset=utf-8,${encodeURIComponent(downloadContent!)}`}
        download={downloadFilename}
      >
        <Button variant="outline" size="sm">
          <Download data-icon="inline-start" />
          Download {granularityLabel}
        </Button>
      </a>
    )}
  </div>

  {children.length > 0 ? (
    <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
      {children.map((child) => (
        <a href={child.href} class="flex flex-col border border-slate-blue-200 rounded-sm p-5 bg-white hover:border-slate-blue-400 dark:bg-card dark:border-border dark:hover:border-slate-blue-600 transition-colors">
          <div class="font-display text-base font-semibold text-slate-blue-700 dark:text-slate-blue-300 mb-1">
            {child.label}
          </div>
          {child.sublabel && (
            <div class="text-sm text-foreground">
              {toTitleCase(child.sublabel)}
            </div>
          )}
          {child.stats.length > 0 && (
            <div class="flex flex-wrap items-center gap-2 mt-auto pt-2 text-xs font-medium text-slate-blue-700 dark:text-slate-blue-400">
              {child.stats
                .filter((stat) => stat.label)
                .map((stat, i) => (
                  <>
                    {i > 0 && <span class="w-px h-3 bg-slate-blue-300 dark:bg-slate-blue-700" />}
                    <span>
                      {typeof stat.value === "number" ? stat.value.toLocaleString() : stat.value}{stat.value ? " " : ""}{stat.label}
                    </span>
                  </>
                ))}
            </div>
          )}
        </a>
      ))}
    </div>
  ) : (
    <div class="border border-slate-blue-200 rounded-sm p-12 bg-white dark:bg-card dark:border-border text-center">
      <p class="text-muted-foreground font-medium">No content available at this level.</p>
    </div>
  )}
</div>
