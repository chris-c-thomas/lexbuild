---
/**
 * Index page for title, chapter, and part views.
 * Shows child items as cards with stats, plus a download button
 * for the current granularity's .md file (if it exists).
 */
import { Button } from "@/components/ui/button";
import { toTitleCase } from "@/lib/utils";
import { getFile } from "@/lib/content";
import type { SourceId, Granularity } from "@/lib/types";
import { Download } from "lucide-react";

interface ChildItem {
  label: string;
  sublabel?: string;
  href: string;
  stats: Array<{ label: string; value: string | number }>;
}

interface Props {
  source: SourceId;
  granularity: Granularity;
  heading: string;
  description?: string;
  children: ChildItem[];
  downloadPath?: string;
  downloadFilename?: string;
}

const { source, granularity, heading, description, children, downloadPath, downloadFilename } = Astro.props;

let downloadAvailable = false;
let downloadContent: string | null = null;
if (downloadPath) {
  downloadContent = await getFile(downloadPath);
  downloadAvailable = downloadContent !== null;
}

const granularityLabel = granularity === "title" ? "Title" : granularity === "chapter" ? "Chapter" : "Part";
---

<div class="flex flex-col gap-6">
  <div class="flex items-start justify-between gap-4">
    <div>
      <h1 class="font-display text-slate-blue-800 dark:text-slate-blue-200 text-2xl font-semibold tracking-tight">
        {toTitleCase(heading)}
      </h1>
      {description && <p class="text-ink-muted mt-1 text-[15px]">{description}</p>}
    </div>
    {
      downloadAvailable && downloadFilename && (
        <>
          <Button variant="outline" size="sm" id="download-btn">
            <Download data-icon="inline-start" />
            Download {granularityLabel}
          </Button>
          <script id="download-content" type="text/plain" data-filename={downloadFilename}>
            {downloadContent}
          </script>
        </>
      )
    }
  </div>

  {
    children.length > 0 ? (
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
        {children.map((child) => (
          <a
            href={child.href}
            class="border-slate-blue-200 hover:border-slate-blue-400 dark:bg-card dark:border-border dark:hover:border-slate-blue-600 flex flex-col rounded-sm border bg-white p-5 transition-colors">
            <div class="font-display text-slate-blue-700 dark:text-slate-blue-300 mb-1 text-base font-semibold">
              {child.label}
            </div>
            {child.sublabel && <div class="text-foreground text-sm">{toTitleCase(child.sublabel)}</div>}
            {child.stats.length > 0 && (
              <div class="text-slate-blue-700 dark:text-slate-blue-400 mt-auto flex flex-wrap items-center gap-2 pt-2 text-xs font-medium">
                {child.stats
                  .filter((stat) => stat.label)
                  .map((stat, i) => (
                    <>
                      {i > 0 && <span class="bg-slate-blue-300 dark:bg-slate-blue-700 h-3 w-px" />}
                      <span>
                        {typeof stat.value === "number" ? stat.value.toLocaleString() : stat.value}
                        {stat.value !== "" ? " " : ""}
                        {stat.label}
                      </span>
                    </>
                  ))}
              </div>
            )}
          </a>
        ))}
      </div>
    ) : (
      <div class="border-slate-blue-200 dark:bg-card dark:border-border rounded-sm border bg-white p-12 text-center">
        <p class="text-muted-foreground font-medium">No content available at this level.</p>
      </div>
    )
  }
</div>

<script>
  document.getElementById("download-btn")?.addEventListener("click", () => {
    const container = document.getElementById("download-content");
    if (!container) return;
    const blob = new Blob([container.textContent || ""], {
      type: "text/markdown;charset=utf-8",
    });
    const url = URL.createObjectURL(blob);
    const a = document.createElement("a");
    a.href = url;
    a.download = container.getAttribute("data-filename") || "download.md";
    a.click();
    URL.revokeObjectURL(url);
  });
</script>
