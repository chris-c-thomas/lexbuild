---
import {
  Breadcrumb,
  BreadcrumbList,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from "@/components/ui/breadcrumb";
import type { Breadcrumb as BreadcrumbType } from "@/lib/types";

interface Props {
  breadcrumbs: BreadcrumbType[];
  /** Optional name appended to the last breadcrumb (e.g. section name). */
  currentPageName?: string;
}

const { breadcrumbs, currentPageName } = Astro.props;
---

<Breadcrumb className="mb-4">
  <BreadcrumbList>
    {breadcrumbs.map((crumb, i) => (
      <>
        {i > 0 && <BreadcrumbSeparator />}
        <BreadcrumbItem>
          {i === breadcrumbs.length - 1 ? (
            <BreadcrumbPage>
              {crumb.label}{currentPageName ? ` — ${currentPageName}` : ""}
            </BreadcrumbPage>
          ) : (
            <BreadcrumbLink href={crumb.href}>{crumb.label}</BreadcrumbLink>
          )}
        </BreadcrumbItem>
      </>
    ))}
  </BreadcrumbList>
</Breadcrumb>
