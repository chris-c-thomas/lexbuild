---
import type { ContentFrontmatter, SourceId } from "@/lib/types";
import { toTitleCase } from "@/lib/utils";
import { highlightYaml } from "@/lib/shiki";

interface Props {
  frontmatter: ContentFrontmatter;
  source: SourceId;
  rawYaml?: string;
}

const { frontmatter, source, rawYaml } = Astro.props;

const isTitle = frontmatter.chapter_count !== undefined;
const isSection = frontmatter.section_number !== undefined;

const fields: Array<{ label: string; value: string }> = [
  { label: "Identifier", value: frontmatter.identifier },
  { label: "Currency", value: frontmatter.currency },
];

if (frontmatter.positive_law !== undefined) {
  fields.push({ label: "Positive Law", value: frontmatter.positive_law ? "Yes" : "No" });
}

fields.push({ label: "Updated", value: frontmatter.last_updated });

if (source === "ecfr" && frontmatter.agency) {
  fields.push({ label: "Agency", value: frontmatter.agency });
}

// FR-specific fields
if (source === "fr") {
  if (frontmatter.document_type) {
    fields.push({ label: "Type", value: frontmatter.document_type.replace(/_/g, " ") });
  }
  if (frontmatter.fr_citation) {
    fields.push({ label: "Citation", value: frontmatter.fr_citation });
  }
  if (frontmatter.publication_date) {
    fields.push({ label: "Published", value: frontmatter.publication_date });
  }
  if (frontmatter.agencies && frontmatter.agencies.length > 0) {
    fields.push({ label: "Agencies", value: frontmatter.agencies.join(", ") });
  }
  if (frontmatter.fr_action) {
    fields.push({ label: "Action", value: frontmatter.fr_action });
  }
  if (frontmatter.effective_date) {
    fields.push({ label: "Effective", value: frontmatter.effective_date });
  }
  if (frontmatter.comments_close_date) {
    fields.push({ label: "Comments Close", value: frontmatter.comments_close_date });
  }
}

if ((isSection || !isTitle) && frontmatter.chapter_name) {
  const chapterLabel =
    frontmatter.chapter_number !== undefined
      ? `${frontmatter.chapter_number} — ${toTitleCase(frontmatter.chapter_name)}`
      : toTitleCase(frontmatter.chapter_name);
  fields.push({ label: "Chapter", value: chapterLabel });
}

if (isTitle) {
  if (frontmatter.chapter_count !== undefined)
    fields.push({ label: "Chapters", value: String(frontmatter.chapter_count) });
  if (frontmatter.section_count !== undefined)
    fields.push({ label: "Sections", value: String(frontmatter.section_count) });
  if (frontmatter.total_token_estimate !== undefined)
    fields.push({ label: "Est. Tokens", value: frontmatter.total_token_estimate.toLocaleString() });
}

const fullWidthFields: Array<{ label: string; value: string }> = [];
if (isSection && frontmatter.source_credit) {
  fullWidthFields.push({ label: "Source", value: frontmatter.source_credit });
}
if (frontmatter.authority) {
  fullWidthFields.push({ label: "Authority", value: frontmatter.authority });
}
if (frontmatter.cfr_references && frontmatter.cfr_references.length > 0) {
  fullWidthFields.push({ label: "CFR References", value: frontmatter.cfr_references.join(", ") });
}
if (frontmatter.docket_ids && frontmatter.docket_ids.length > 0) {
  fullWidthFields.push({ label: "Docket IDs", value: frontmatter.docket_ids.join(", ") });
}
if (frontmatter.rin) {
  fullWidthFields.push({ label: "RIN", value: frontmatter.rin });
}

const rawYamlBlock = rawYaml ? `---\n${rawYaml.trim()}\n---` : "";
const highlightedYaml = rawYamlBlock ? await highlightYaml(rawYamlBlock) : "";
const hasToggle = !!rawYaml;
---

<div class="frontmatter-wrapper" data-frontmatter-toggle>
  <!-- Toolbar header — matches ContentViewer toolbar style -->
  {
    hasToggle ? (
      <div class="fm-toolbar">
        <div class="fm-tabs-list">
          <button class="fm-tabs-trigger active" data-view="raw" type="button" aria-pressed="true">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round">
              <>
                <path d="M15 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V7Z" />
                <path d="M14 2v4a2 2 0 0 0 2 2h4" />
                <path d="M10 9H8" />
                <path d="M16 13H8" />
                <path d="M16 17H8" />
              </>
            </svg>
            YAML
          </button>
          <button class="fm-tabs-trigger" data-view="rendered" type="button" aria-pressed="false">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round">
              <>
                <path d="M2.062 12.348a1 1 0 0 1 0-.696 10.75 10.75 0 0 1 19.876 0 1 1 0 0 1 0 .696 10.75 10.75 0 0 1-19.876 0" />
                <circle cx="12" cy="12" r="3" />
              </>
            </svg>
            Preview
          </button>
        </div>
      </div>
    ) : null
  }

  <!-- Raw YAML view (shown by default when toggle present) -->
  {
    hasToggle ? (
      <div class="fm-content fm-content-bottom frontmatter-yaml-view" data-frontmatter-view="raw">
        <Fragment set:html={highlightedYaml} />
      </div>
    ) : null
  }

  <!-- Rendered view (hidden by default when toggle present, shown when no toggle) -->
  <div
    class:list={[hasToggle ? "fm-content fm-content-bottom" : "fm-content fm-content-standalone"]}
    data-frontmatter-view="rendered"
    style={hasToggle ? "display: none;" : undefined}>
    <dl class="frontmatter-grid">
      {
        fields.map((field) => (
          <div class="frontmatter-cell">
            <dt class="frontmatter-label">{field.label}</dt>
            <dd class="frontmatter-value">{field.value}</dd>
          </div>
        ))
      }
    </dl>

    {
      fullWidthFields.map((field) => {
        const isLong = field.value.length > 200;
        return (
          <dl class="frontmatter-full">
            <dt class="frontmatter-label">{field.label}</dt>
            {isLong ? (
              <dd class="frontmatter-value frontmatter-collapsible" data-collapsed="true">
                <span class="frontmatter-collapsed-text">{field.value.slice(0, 200)}...</span>
                <span class="frontmatter-expanded-text" style="display:none;">
                  {field.value}
                </span>
                <button class="frontmatter-show-more" type="button" aria-expanded="false">
                  Show more
                </button>
              </dd>
            ) : (
              <dd class="frontmatter-value">{field.value}</dd>
            )}
          </dl>
        );
      })
    }
  </div>
</div>

<script is:inline>
  document.querySelectorAll(".frontmatter-show-more").forEach((btn) => {
    btn.addEventListener("click", () => {
      var dd = btn.closest(".frontmatter-collapsible");
      if (!dd) return;
      var isCollapsed = dd.dataset.collapsed === "true";
      dd.dataset.collapsed = isCollapsed ? "false" : "true";
      var collapsed = dd.querySelector(".frontmatter-collapsed-text");
      var expanded = dd.querySelector(".frontmatter-expanded-text");
      if (collapsed) collapsed.style.display = isCollapsed ? "none" : "";
      if (expanded) expanded.style.display = isCollapsed ? "" : "none";
      btn.textContent = isCollapsed ? "Show less" : "Show more";
      btn.setAttribute("aria-expanded", isCollapsed ? "true" : "false");
    });
  });

  document.querySelectorAll("[data-frontmatter-toggle]").forEach((wrapper) => {
    var buttons = wrapper.querySelectorAll(".fm-tabs-trigger");
    var views = wrapper.querySelectorAll("[data-frontmatter-view]");

    buttons.forEach(function (btn) {
      btn.addEventListener("click", function () {
        var target = btn.dataset.view;
        buttons.forEach(function (b) {
          var isActive = b.dataset.view === target;
          b.classList.toggle("active", isActive);
          b.setAttribute("aria-pressed", String(isActive));
        });
        views.forEach(function (v) {
          v.style.display = v.dataset.frontmatterView === target ? "" : "none";
        });
      });
    });
  });
</script>

<style>
  .frontmatter-wrapper {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  /* Toolbar — matches ContentViewer's border-border bg-muted/40 rounded-t-md border */
  .fm-toolbar {
    display: flex;
    align-items: center;
    border: 1px solid var(--border);
    border-radius: calc(var(--radius) - 2px) calc(var(--radius) - 2px) 0 0;
    background: color-mix(in oklch, var(--muted) 40%, transparent);
    padding: 0.5rem 1rem;
  }

  /* Tabs list inside toolbar — matches shadcn TabsList */
  .fm-tabs-list {
    display: inline-flex;
    width: fit-content;
    align-items: center;
    border-radius: 0.5rem;
    padding: 0.25rem;
    background: var(--muted);
    color: var(--muted-foreground);
  }

  /* Tab trigger — matches shadcn TabsTrigger */
  .fm-tabs-trigger {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    border-radius: calc(var(--radius) - 2px);
    border: 1px solid transparent;
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
    font-weight: 500;
    white-space: nowrap;
    background: transparent;
    color: color-mix(in oklch, var(--foreground) 60%, transparent);
    cursor: pointer;
    transition: all 150ms;
  }

  .fm-tabs-trigger:hover {
    color: var(--color-slate-blue-700, #476c85);
  }

  .fm-tabs-trigger.active {
    background: var(--background);
    color: var(--color-slate-blue-700, #476c85);
    border-color: transparent;
    box-shadow: 0 1px 2px 0 rgb(0 0 0 / 0.05);
  }

  :global(.dark) .fm-tabs-trigger {
    color: var(--muted-foreground);
  }

  :global(.dark) .fm-tabs-trigger:hover {
    color: var(--color-slate-blue-300, #b4cfda);
  }

  :global(.dark) .fm-tabs-trigger.active {
    background: color-mix(in oklch, var(--input) 30%, transparent);
    color: var(--color-slate-blue-300, #b4cfda);
    border-color: var(--input);
    box-shadow: none;
  }

  .fm-tabs-trigger svg {
    pointer-events: none;
    flex-shrink: 0;
  }

  /* Content area below toolbar */
  .fm-content {
    border: 1px solid var(--border);
    background: var(--background);
  }

  .fm-content-bottom {
    border-top: none;
    border-radius: 0 0 calc(var(--radius) - 2px) calc(var(--radius) - 2px);
  }

  .fm-content-standalone {
    border-radius: calc(var(--radius) * 0.6);
  }

  .frontmatter-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
  }

  .frontmatter-cell {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--border);
  }

  .frontmatter-cell + .frontmatter-cell {
    border-left: 1px solid var(--border);
  }

  .frontmatter-full {
    padding: 0.75rem 1rem;
    border-top: 1px solid var(--border);
  }

  .frontmatter-grid:last-child .frontmatter-cell {
    border-bottom: none;
  }

  .frontmatter-label {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--color-summer-green-700, #487061);
  }

  :global(.dark) .frontmatter-label {
    color: var(--color-summer-green-400, #98b8ab);
  }

  .frontmatter-value {
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--foreground);
    overflow-wrap: break-word;
  }

  .frontmatter-show-more {
    display: inline;
    margin-left: 0.375rem;
    padding: 0;
    border: none;
    background: none;
    color: var(--color-slate-blue-700, #476c85);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
  }

  .frontmatter-show-more:hover {
    text-decoration: underline;
  }

  :global(.dark) .frontmatter-show-more {
    color: var(--color-slate-blue-400, #8ab8d0);
  }

  .frontmatter-yaml-view :global(pre.shiki) {
    margin: 0;
    padding: 1rem;
    font-size: 0.8rem;
    line-height: 1.6;
    white-space: pre-wrap;
    word-break: break-word;
    border-radius: 0;
    background: transparent !important;
  }

  /* YAML keys at medium weight, values stay at regular.
     Targets Shiki's inline style — the light-theme color is always present
     in the style attribute regardless of dark mode (dark uses --shiki-dark var).
     Case-insensitive flag (i) handles Shiki's uppercase hex output (#476C85). */
  .frontmatter-yaml-view :global(pre.shiki span[style*="color:#476C85" i]) {
    font-weight: 600;
  }
</style>
