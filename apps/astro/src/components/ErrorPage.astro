---
interface Props {
  status: number;
  title: string;
  description: string;
  /** Show "Back to home" link. Default: true. */
  showHomeLink?: boolean;
}

const { status, title, description, showHomeLink = true } = Astro.props;
---

<div
  class="mx-auto flex max-w-7xl flex-col items-center justify-center px-4 py-24 text-center sm:px-6 lg:px-8"
>
  <p class="text-slate-blue-200/60 dark:text-slate-blue-300/40 text-6xl font-bold" aria-hidden="true">
    {status}
  </p>
  <h1 class="text-foreground mt-4 text-lg font-medium">{title}</h1>
  <p class="text-muted-foreground mt-2 max-w-md text-base">{description}</p>
  {
    showHomeLink ? (
      <a
        href="/"
        class="text-slate-blue-700 hover:text-slate-blue-800 dark:text-slate-blue-400 dark:hover:text-slate-blue-300 mt-6 inline-flex items-center gap-1.5 text-sm font-medium transition-colors"
      >
        &larr; Back to home
      </a>
    ) : null
  }
</div>
