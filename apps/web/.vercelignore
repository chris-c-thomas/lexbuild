# Vercel deploy ignore — overrides .gitignore entirely.
# Content is served from R2, not the filesystem.

node_modules/
.turbo/
.next/
*.tsbuildinfo

# Content (served from R2 in production)
content/
downloads/

# Dev-only scripts (not needed at runtime)
scripts/

# PageFind index (served from R2, too large for Vercel static hosting)
public/_pagefind/

# Dev config
.env.local
CLAUDE.md
components.json
