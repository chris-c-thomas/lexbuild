# Content provider: "fs" for local file system, "s3" for production AWS S3 / Cloudflare R2.
CONTENT_STORAGE=fs

# Filesystem provider (local dev only)
CONTENT_DIR=/absolute/path/to/apps/web/content

# S3/R2 provider (production — set these in Vercel)
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_BUCKET=lexbuild-content
# R2_ACCESS_KEY_ID=<your-access-key-id>
# R2_SECRET_ACCESS_KEY=<your-secret-access-key>
# R2_REGION=auto

# PageFind base URL
# Local:
# Defaults to "/_pagefind"
# Production:
# NEXT_PUBLIC_PAGEFIND_BASE_URL=<public-r2-url>/_pagefind
