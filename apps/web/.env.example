# Content provider: "fs" for local development, "s3" for Cloudflare R2 / S3
CONTENT_STORAGE=fs

# Filesystem provider (local dev only)
CONTENT_DIR=/absolute/path/to/apps/web/content

# S3/R2 provider (production)
# R2_ENDPOINT=https://<ACCOUNT_ID>.r2.cloudflarestorage.com
# R2_BUCKET=lexbuild-content
# R2_ACCESS_KEY_ID=<your-access-key-id>
# R2_SECRET_ACCESS_KEY=<your-secret-access-key>
# R2_REGION=auto

# PageFind base URL (production — serve from R2 public URL instead of local static files)
# NEXT_PUBLIC_PAGEFIND_BASE_URL=https://cdn.lexbuild.dev/_pagefind
