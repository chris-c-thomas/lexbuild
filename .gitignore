# .gemini/styleguide.md

# Skills
skills-lock.json

# Plugins

# MCPs
.playwright-mcp/

# -----------------------------------------------------------------------------
# LexBuild CLI
# -----------------------------------------------------------------------------

# Downloaded Source Files (Large, Regenerable)
downloads/

# Converted Markdown Output (Regenerable from Source XML)
output/
output-chapter/
output-part/
output-title/

# Test Output
test-output/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
