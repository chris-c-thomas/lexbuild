# =============================================================================
# lexbuild .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Dependencies
# -----------------------------------------------------------------------------
node_modules/

# -----------------------------------------------------------------------------
# Build outputs
# -----------------------------------------------------------------------------
dist/
*.tsbuildinfo
*.tsbuildinfo.*
*.metafile.json

# -----------------------------------------------------------------------------
# Turborepo
# -----------------------------------------------------------------------------
.turbo/

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.js.map
*.d.ts.map

# Don't ignore .js and .d.ts globally — only dist/ matters.
# Source is TypeScript-only; emitted JS lives exclusively in dist/.

# -----------------------------------------------------------------------------
# Testing & coverage
# -----------------------------------------------------------------------------
coverage/
.vitest/
*.lcov

# -----------------------------------------------------------------------------
# Environment & secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# AI coding agents
# -----------------------------------------------------------------------------

# Agents
/.agents/

# Skills
skills-lock.json

# Claude Code
/.claude/
.mcp.json

# Cursor
.cursorignore
.cursorindexingignore

# Codex / OpenAI
/.codex/

# -----------------------------------------------------------------------------
# OS metadata
# -----------------------------------------------------------------------------

# macOS
.DS_Store
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
.directory

# -----------------------------------------------------------------------------
# IDEs & editors
# -----------------------------------------------------------------------------

# Backup/swap files (Vim, Emacs, etc.)
*~
*.swp
*.swo
*.swn
\#*\#
.\#*
*.elc
Session.vim
.netrwhist
tags

# VS Code — workspace settings are personal; extensions.json can be committed
# separately if the team agrees on shared recommendations.
.vscode/*
!.vscode/extensions.json

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Zed
.zed/

# -----------------------------------------------------------------------------
# lexbuild operational outputs
# -----------------------------------------------------------------------------

# Downloaded source files (large, regenerable)
downloads/

# Legacy locations for downloaded XML
xml/
fixtures/xml/

# USLM reference materials (PDF, XSD, CSS — available from OLRC)
docs/reference/uslm/

# AI agent transcripts
docs/transcripts/

# Converted Markdown output (regenerable from source XML)
output/

# Test output from local development runs
test-output/

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
logs/

# -----------------------------------------------------------------------------
# Archives & binaries
# -----------------------------------------------------------------------------
*.zip
*.tar.gz
*.tgz
*.rar
*.7z

# -----------------------------------------------------------------------------
# Other package managers (not used — this project uses pnpm)
# -----------------------------------------------------------------------------
package-lock.json
.yarn/
.yarnrc.yml
yarn.lock
.pnp.*
bun.lockb
bun.lock
.pnpm-store/

# Verdaccio local registry (if used for testing publishes locally)
.verdaccio/
storage/
