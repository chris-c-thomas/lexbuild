# -----------------------------------------------------------------------------
dist/
*.tsbuildinfo
*.tsbuildinfo.*
*.metafile.json

# -----------------------------------------------------------------------------
# Turborepo
# -----------------------------------------------------------------------------
.turbo/

# Vercel (No Longer Used)
.vercel/

# -----------------------------------------------------------------------------
# TypeScript
# -----------------------------------------------------------------------------
*.js.map
*.d.ts.map

# -----------------------------------------------------------------------------
# Testing & Coverage
# -----------------------------------------------------------------------------
coverage/
.vitest/
*.lcov

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example

# -----------------------------------------------------------------------------
# AI, IDE, and Other Editor Metadata
# -----------------------------------------------------------------------------

# Backup/Swap Files
*~
*.swp
*.swo
*.swn
\#*\#
.\#*
*.elc
Session.vim
.netrwhist
tags

# VS Code
.vscode/*
!.vscode/extensions.json

# Cursor
.cursor/
.cursorignore
.cursorindexingignore

# Zed
.zed/

# JetBrains
.idea/
*.iml

# Sublime Text
*.sublime-project
*.sublime-workspace

# Agents
/.agents/

# Anthropic
/.claude/
.mcp.json

# OpenAI
/.codex/

# Google
/.gemini/
