# Vercel deploy ignore — monorepo root
# Root directory is set to apps/web in Vercel dashboard,
# but the full repo is uploaded so pnpm-lock.yaml is available.

# Downloaded XML files (large, not needed for build)
downloads/

# Converted output (not needed — production reads from R2)
output/
test-output/

# Web app generated content (served from R2, not filesystem)
apps/web/content/
apps/web/public/_pagefind/
apps/web/public/nav/

# Package build artifacts (rebuilt during Vercel build)
packages/*/dist/

# Test fixtures and docs
fixtures/
docs/

# Dev config
apps/web/.env.local
.claude/
