{
  "name": "@lexbuild/core",
  "version": "1.18.0",
  "description": "Core AST definitions, parsing infrastructure, and format-agnostic renderers for the LexBuild ecosystem.",
  "author": "Chris Thomas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chris-c-thomas/LexBuild.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/chris-c-thomas/LexBuild/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/chris-c-thomas/LexBuild/issues"
  },
  "keywords": [
    "lexbuild",
    "legal-tech",
    "law",
    "rag",
    "llm",
    "ast",
    "xml",
    "compiler",
    "parser",
    "schema",
    "structured-data",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "saxes": "^6.0.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8",
    "typescript": "^5.8",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
