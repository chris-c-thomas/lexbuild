{
  "name": "@law2md/core",
  "version": "0.3.0",
  "description": "Core XML parsing, AST, and Markdown rendering for law2md",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "saxes": "^6.0.0",
    "tiktoken": "^1.0.21",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "tsup": "^8",
    "typescript": "^5.8",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=20"
  }
}
