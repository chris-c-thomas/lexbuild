{
  "name": "@lexbuild/cli",
  "version": "1.17.1",
  "description": "Compiler for legal and civic texts. Converts disparate statutory data into structured formats optimized for AI, RAG, and semantic search.",
  "author": "Chris Thomas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chris-c-thomas/LexBuild.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/chris-c-thomas/LexBuild/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/chris-c-thomas/LexBuild/issues"
  },
  "keywords": [
    "lexbuild",
    "legal-tech",
    "civic-tech",
    "law",
    "cli",
    "rag",
    "llm",
    "xml",
    "compiler",
    "uscode",
    "uslm",
    "federal-law",
    "olrc",
    "structured-data",
    "semantic-search",
    "markdown",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lexbuild": "./dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@lexbuild/core": "workspace:*",
    "@lexbuild/ecfr": "workspace:*",
    "@lexbuild/fr": "workspace:*",
    "@lexbuild/usc": "workspace:*",
    "better-sqlite3": "^11.9",
    "chalk": "^5.6.2",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "gray-matter": "^4.0",
    "ora": "^8.2.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6",
    "@types/node": "^25.3.2",
    "tsup": "^8",
    "typescript": "^5.8",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
