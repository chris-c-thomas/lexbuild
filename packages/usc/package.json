{
  "name": "@lexbuild/usc",
  "version": "1.6.0",
  "description": "Federal U.S. Code specific element handlers and downloader for LexBuild",
  "author": "Chris Thomas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/chris-c-thomas/LexBuild.git",
    "directory": "packages/usc"
  },
  "homepage": "https://github.com/chris-c-thomas/LexBuild/tree/main/packages/usc",
  "bugs": {
    "url": "https://github.com/chris-c-thomas/LexBuild/issues"
  },
  "keywords": [
    "lexbuild",
    "legal-tech",
    "law",
    "rag",
    "llm",
    "xml",
    "parser",
    "uscode",
    "uslm",
    "statutes",
    "federal-law",
    "olrc",
    "typescript"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix"
  },
  "dependencies": {
    "@lexbuild/core": "workspace:*",
    "yauzl": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.2",
    "@types/yauzl": "^2.10.3",
    "tsup": "^8",
    "typescript": "^5.8",
    "vitest": "^3"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  }
}
