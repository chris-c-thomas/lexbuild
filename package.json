{
  "name": "lexbuild",
  "version": "1.7.0",
  "private": true,
  "author": "Chris Thomas",
  "license": "MIT",
  "homepage": "https://github.com/chris-c-thomas/LexBuild#readme",
  "bugs": {
    "url": "https://github.com/chris-c-thomas/LexBuild/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chris-c-thomas/LexBuild.git"
  },
  "keywords": [
    "lexbuild",
    "legal-tech",
    "civic-tech",
    "law",
    "cli",
    "rag",
    "llm",
    "ast",
    "xml",
    "compiler",
    "parser",
    "schema",
    "uscode",
    "uslm",
    "statutes",
    "federal-law",
    "olrc",
    "structured-data",
    "semantic-search",
    "markdown",
    "typescript",
    "monorepo"
  ],
  "type": "module",
  "packageManager": "pnpm@10.30.3",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "turbo build",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "dev": "turbo dev",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "release:local": "turbo build && changeset publish"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.3.2",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "turbo": "^2",
    "typescript-eslint": "^8.56.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
